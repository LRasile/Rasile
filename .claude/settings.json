{
  "permissions": {
    "allow": [
      "Bash(yarn:*)",
      "Bash(yarn dev:*)",
      "Bash(yarn build:*)",
      "Bash(yarn lint:*)",
      "Bash(powershell -File git.ps1:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)"
    ]
  },
  "statusLine": "{model} | {cost} | ctx: {contextPct}% | {session}",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ]
  }
}
